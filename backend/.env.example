# development | production — em production, exceptions não tratadas viram 500 sanitizado.
APP_ENV=development

# Postgres (saída de `supabase start` em dev, dashboard em prod)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase
# Auth: validação ES256 via JWKS pública em {SUPABASE_URL}/auth/v1/.well-known/jwks.json
# (não é mais necessário um segredo simétrico — Supabase Cloud usa chaves assimétricas).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=stirps-media

# Comma-separated. Inclua o domínio que serve o frontend.
CORS_ORIGINS=http://localhost:8000,http://cassiorodrigues.tech
