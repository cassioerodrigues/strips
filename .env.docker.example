# Copy to .env and fill these values when you want the full app with auth/API.
#
# Supabase local via `supabase start` from the host:
# DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres
# SUPABASE_URL=http://host.docker.internal:54321
# STIRPS_SUPABASE_URL=http://localhost:54321
#
# Supabase Cloud:
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# SUPABASE_URL=https://<project-ref>.supabase.co
# STIRPS_SUPABASE_URL=https://<project-ref>.supabase.co

APP_ENV=development
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=stirps-media
STIRPS_SUPABASE_URL=
STIRPS_SUPABASE_ANON_KEY=

# Optional local Docker overrides. Keep these local defaults unless you put a
# reverse proxy in front of both services.
DOCKER_STIRPS_API_BASE_URL=http://localhost:8001/api
DOCKER_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
